{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@dovuto/data": ["../../packages/data/src/index.ts"],
      "@dovuto/hooks": ["../../packages/hooks/src/index.ts"],
      "@dovuto/ui": ["../../packages/ui/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
