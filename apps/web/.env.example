# ─── Dovuto Web — Variabili d'ambiente ───────────────────────────────
# Copia questo file in .env.local e compila con i valori reali.
# .env.local è già in .gitignore — non verrà mai committato.

# Stripe (pagamenti) — usa chiavi LIVE in produzione, TEST in sviluppo
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Supabase (auth + database) — quando integrato
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxx

# URL pubblico dell'app (per redirect Stripe e Open Graph)
VITE_APP_URL=https://dovuto.it
